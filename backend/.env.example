# 应用
APP_NAME=JavaDoctor
DEBUG=true
API_PREFIX=/api

# 安全 / JWT
SECRET_KEY=change-me-in-prod-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# 数据库 (开发默认 SQLite, 可切 PostgreSQL)
DATABASE_URL=sqlite:///./data/javadoctor.db

# Redis (可选, 留空则降级内存缓存)
REDIS_URL=redis://localhost:6379/0

# Ollama LLM (qwen3.5:4b 支持 think 关闭, 输出干净不含思考段)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3.5:4b

# 嵌入模型 (走 Ollama)
EMBEDDING_MODEL=bge-m3

# ChromaDB (嵌入式, 本地持久化目录)
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION=java_interview

# 文件上传
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=50

# 超级管理员 (启动时自动播种)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

# CORS (前端地址)
CORS_ORIGINS=http://localhost:5173
